import React, { useState, useRef } from 'react';
import { StyleSheet, Text, View, TouchableOpacity, ScrollView, SafeAreaView, StatusBar } from 'react-native';

// Definição da estrutura do objeto de cada volta para o TypeScript
interface Volta {
  id: string;
  numero: number;
  tempoFormatado: string;
}

export default function CronometroScreen() {
  // Estados tipados para o tempo (ms), status e lista de voltas
  const [tempo, setTempo] = useState<number>(0);
  const [rodando, setRodando] = useState<boolean>(false);
  const [voltas, setVoltas] = useState<Volta[]>([]);
  
  // useRef tipado para armazenar a referência do intervalo
  const intervaloRef = useRef<ReturnType<typeof setInterval> | null>(null);

  // Inicia ou continua a contagem do cronômetro
  const iniciarCronometro = (): void => {
    if (!rodando) {
      setRodando(true);
      const startTime = Date.now() - tempo;
      
      intervaloRef.current = setInterval(() => {
        setTempo(Date.now() - startTime);
      }, 10); // Atualização precisa a cada 10 milissegundos (centésimos)
    }
  };

  // Pausa a contagem sem zerar os dados
  const pausarCronometro = (): void => {
    if (rodando && intervaloRef.current) {
      clearInterval(intervaloRef.current);
      intervaloRef.current = null;
      setRodando(false);
    }
  };

  // Reseta todos os estados para o valor original
  const resetarCronometro = (): void => {
    if (intervaloRef.current) {
      clearInterval(intervaloRef.current);
      intervaloRef.current = null;
    }
    setRodando(false);
    setTempo(0);
    setVoltas([]);
  };

  // Registra o tempo atual na lista de voltas
  const registrarVolta = (): void => {
    if (tempo > 0) {
      const novaVolta: Volta = {
        id: Date.now().toString(),
        numero: voltas.length + 1,
        tempoFormatado: formatarTempo(tempo),
      };
      // Adiciona o novo registro no início da lista
      setVoltas([novaVolta, ...voltas]);
    }
  };

  // Formata os milissegundos totais no padrão exigido: MM:SS.cc
  const formatarTempo = (ms: number): string => {
    const minutos = Math.floor(ms / 60000);
    const segundos = Math.floor((ms % 60000) / 1000);
    const centesimos = Math.floor((ms % 1000) / 10);

    const pad = (num: number): string => num.toString().padStart(2, '0');

    return `${pad(minutos)}:${pad(segundos)}.${pad(centesimos)}`;
  };

  return (
    <SafeAreaView style={styles.containerAmbiente}>
      <StatusBar barStyle="dark-content" backgroundColor="#F3F4F6" />

      {/* ================= MAQUETE FÍSICA ESTILO GALAXY A50 (EM PÉ) ================= */}
      <View style={styles.aparelhoSamsungA50}>
        <View style={styles.telaInifinityU}>
          
          {/* Câmera Frontal Estilo Notch Gota (Infinity-U do A50) */}
          <View style={styles.notchInfinityU} />

          {/* Seção Superior - Display Circular Minimalista Dourado */}
          <View style={styles.sessaoSuperior}>
            <View style={styles.circuloAnelFino}>
              <Text style={styles.textoTempoPrincipal}>{formatarTempo(tempo)}</Text>
            </View>
          </View>

          {/* Seção Central - Painel com os 3 Botões Circulares Alinhados */}
          <View style={styles.sessaoMedia}>
            <View style={styles.botoesContainer}>
              
              {/* Botão de Registro de Volta */}
              <TouchableOpacity 
                style={[styles.botaoCircular, !rodando && styles.botaoDesativado]} 
                onPress={registrarVolta}
                disabled={!rodando}
              >
                <Text style={styles.textoBotao}>Volta</Text>
              </TouchableOpacity>

              {/* Botão Dinâmico Principal: Iniciar / Continuar / Pausar */}
              {!rodando ? (
                <TouchableOpacity style={[styles.botaoCircular, styles.botaoDestaque]} onPress={iniciarCronometro}>
                  <Text style={styles.textoBotaoDestaque}>{tempo > 0 ? 'Continuar' : 'Iniciar'}</Text>
                </TouchableOpacity>
              ) : (
                <TouchableOpacity style={[styles.botaoCircular, styles.botaoDestaque]} onPress={pausarCronometro}>
                  <Text style={styles.textoBotaoDestaque}>Pausar</Text>
                </TouchableOpacity>
              )}

              {/* Botão Reset */}
              <TouchableOpacity style={styles.botaoCircular} onPress={resetarCronometro}>
                <Text style={styles.textoBotao}>Reset</Text>
              </TouchableOpacity>
              
            </View>
          </View>

          {/* Seção Inferior - Histórico Alongado de Voltas */}
          <View style={styles.sessaoInferior}>
            <Text style={styles.subtituloListagem}>Voltas Registradas</Text>
            <ScrollView style={styles.listaContainer} showsVerticalScrollIndicator={false}>
              {voltas.map((item) => (
                <View key={item.id} style={styles.voltaItemLinha}>
                  <Text style={styles.txtVoltaNumero}>Volta {item.numero.toString().padStart(2, '0')}</Text>
                  <Text style={styles.txtVoltaTempo}>{item.tempoFormatado}</Text>
                </View>
              ))}
            </ScrollView>
          </View>

          {/* Barra de Navegação por Gestos do Android */}
          <View style={styles.barraNavegacaoAndroid} />

        </View>
      </View>
    </SafeAreaView>
  );
}

